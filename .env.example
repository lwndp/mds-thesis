# Copy to .env and fill in values.

# PostgreSQL connection URL for the Open Discourse database.
# If the DB is on a remote server (such as DS01), open a tunnel first:
#   ssh -L 5433:localhost:5432 ds01 -N
# then use port 5433 here.
DB_CON_STRING=postgresql://postgres:postgres@localhost:5432/next

# Root directory for all data files, relative to the repo root.
# Defaults to "data" if unset. Override if your data lives elsewhere (e.g. on a mounted drive).
DATA_PATH=data